<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TVLiveApp" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="android:colorPrimary">@color/purple_500</item>
        <item name="android:colorPrimaryDark">@color/purple_700</item>
        <item name="android:colorAccent">@color/teal_200</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/purple_700</item>
        
        <!-- Window background. -->
        <item name="android:windowBackground">@color/tv_background</item>
        
        <!-- No action bar for full screen experience -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>
    
    <!-- TV Theme for Leanback -->
    <style name="Theme.TVLiveApp.Leanback" parent="Theme.Leanback">
        <item name="android:colorPrimary">@color/purple_500</item>
        <item name="android:windowBackground">@color/tv_background</item>
    </style>
</resources>
